# Environment Configuration for BRS Consolidator

# LLM Provider Configuration (Using Ollama by default)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=https://ollama.icicilabs.com

# Optional: Uncomment to use cloud providers instead
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# Model Configuration
# LLM_MODEL=maryasov/qwen2.5-coder-cline:32b
LLM_MODEL=llama3.1:latest
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Vector Store Configuration
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma_db

# Retrieval Configuration
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# Processing Configuration
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=100
